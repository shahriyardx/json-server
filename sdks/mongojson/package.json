{
  "name": "mongojson",
  "version": "0.1.3",
  "description": "MongoDB-compatible SDK for json-server — use MongoDB-like operations on top of a REST API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shahriyardx/json-server.git",
    "directory": "sdk-mongojson"
  },
  "homepage": "https://github.com/shahriyardx/json-server#readme",
  "bugs": {
    "url": "https://github.com/shahriyardx/json-server/issues"
  },
  "author": "Shahriyar",
  "license": "MIT",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "bun test --env-file=.env",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "json-server",
    "mongodb",
    "sdk",
    "rest"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "tsup": "^8",
    "typescript": "^5"
  }
}
